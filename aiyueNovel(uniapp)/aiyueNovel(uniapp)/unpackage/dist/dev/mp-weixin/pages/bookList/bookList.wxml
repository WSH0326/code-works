<view class="container"><view class="page-container"><block wx:for="{{bookList}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view class="novelcontainer"><view class="containbox" data-id="{{item.id}}" data-event-opts="{{[['tap',[['getBookInfo',['$event']]]]]}}" bindtap="__e"><view class="novelimg"><image class="cover-placeholder" src mode="aspectFill"></image></view><view class="novelinfo"><view id="novelname">{{item.bookName}}</view><view id="bookauthor">{{item.authorName}}</view><view class="noveldesc">{{item.desc||'暂无简介'}}</view></view></view></view></block></view></view>