<view class="container"><view class="toolbar"><text data-event-opts="{{[['tap',[['getLastIndex',['$event']]]]]}}" bindtap="__e">上一章</text><text data-event-opts="{{[['tap',[['getAllIndex',['$event']]]]]}}" bindtap="__e">目录</text><text data-event-opts="{{[['tap',[['getNextIndex',['$event']]]]]}}" bindtap="__e">下一章</text></view><block wx:if="{{!$root.m0}}"><view class="content-wrap"><view class="chapter-title">{{Indextext.title}}</view><view class="chapter-content">{{Indextext.content}}</view></view></block><block wx:else><view class="empty-tip">暂无章节内容</view></block></view>