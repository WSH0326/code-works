
.loading {
	text-align: center;
	padding: 40rpx;
	font-size: 28rpx;
	color: #666;
}
.empty-shelf {
	text-align: center;
	padding: 80rpx 0;
}
.empty-shelf text {
	display: block;
	margin-bottom: 30rpx;
	color: #999;
}
.empty-shelf button {
	background: #2b6cbc;
	color: white;
	border-radius: 50rpx;
}
.shelf-container {
	padding: 20rpx;
}
.book-card {
	display: flex;
	align-items: center;
	justify-content: space-between;
	background: white;
	border-radius: 16rpx;
	padding: 25rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}
.book-main {
	display: flex;
	align-items: center;
	flex: 1;
}
.cover {
	width: 120rpx;
	height: 160rpx;
	border-radius: 8rpx;
	margin-right: 20rpx;
	background: #f5f5f5;
}
.book-info {
	flex: 1;
}
.book-name {
	font-size: 32rpx;
	font-weight: bold;
	display: block;
	margin-bottom: 10rpx;
}
.author {
	font-size: 26rpx;
	color: #999;
}
.del-btn {
	font-size: 24rpx;
	background: #ff4444;
	color: white;
	border-radius: 30rpx;
	padding: 8rpx 20rpx;
	border: none;
	margin-left: 20rpx;
}

