<view class="container"><block wx:if="{{loading}}"><view class="loading"> 加载书架中... </view></block><block wx:else><block wx:if="{{empty}}"><view class="empty-shelf"><text>你的书架还是空的~</text><button data-event-opts="{{[['tap',[['goToHome',['$event']]]]]}}" bindtap="__e">去添加书籍</button></view></block><block wx:else><view class="shelf-container"><block wx:for="{{shelfList}}" wx:for-item="item" wx:for-index="index" wx:key="Id"><view class="book-card"><view class="book-main" data-id="{{item.Id}}" data-firstindexid="{{item.firstIndexId}}" data-event-opts="{{[['tap',[['toReadBook',['$event']]]]]}}" bindtap="__e"><image class="cover" src="{{item.picUrl||'/static/default-cover.png'}}"></image><view class="book-info"><text class="book-name">{{item.bookName}}</text><block wx:if="{{item.authorName}}"><text class="author">{{"作者："+item.authorName}}</text></block></view></view><button class="del-btn" data-id="{{item.Id}}" data-event-opts="{{[['tap',[['removeFromShelf',['$event']]]]]}}" bindtap="__e"> 移除 </button></view></block></view></block></block></view>