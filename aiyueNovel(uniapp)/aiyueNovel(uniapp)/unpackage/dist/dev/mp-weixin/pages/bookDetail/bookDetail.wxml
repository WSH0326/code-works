<view class="container"><view class="detail-container"><block wx:if="{{loading}}"><view class="loading">加载中...</view></block><block wx:else><view class="book-detail"><view class="book-pic"><image class="cover-placeholder" src mode></image></view><view class="book-base-info"><text class="book-name">{{bookInfo.bookName}}</text><view class="book-author">{{"作者："+bookInfo.authorName}}</view><view class="book-category">{{"类别："+(bookInfo.catName||'未知分类')}}</view><view>{{"状态："+(bookInfo.status===1?'连载中':'已完结')}}</view><view>{{"更新："+(bookInfo.year||'暂无')}}</view><view class="book-word-count">{{"评分："+(bookInfo.score||0)}}</view><view class="book-visit-count">{{"点击："+(bookInfo.visitCount||0)}}</view></view><view class="btn-group"><view data-event-opts="{{[['tap',[['beginRead',['$event']]]]]}}" class="custom-btn btn-read" bindtap="__e">开始阅读</view><view data-event-opts="{{[['tap',[['addToBookshelf',['$event']]]]]}}" class="custom-btn btn-shelf" bindtap="__e">加入书架</view></view><view class="book-desc"><text class="desc-title">书籍简介：</text><rich-text nodes="{{bookInfo.bookDesc}}"></rich-text></view><view class="collapse-title">最新章节</view><view class="collapse-content"><block wx:for="{{newIndex}}" wx:for-item="item" wx:for-index="index" wx:key="id"><view data-bookindexid="{{item.id}}" data-event-opts="{{[['tap',[['getIndex',['$event']]]]]}}" bindtap="__e">{{''+item.indexName+''}}</view></block></view><view data-event-opts="{{[['tap',[['getAllIndex',['$event']]]]]}}" class="cell-item" bindtap="__e"><text>完整目录</text><text>></text></view></view></block></view></view>